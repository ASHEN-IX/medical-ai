# .env.example - MedAI Nexus Environment Template

## 🔐 IMPORTANT SECURITY NOTES
- NEVER commit actual .env files (they're gitignored)
- NEVER commit secrets/API keys
- Copy this file to .env.local for local development
- Use proper secret management in production (AWS Secrets Manager, Vault, etc.)

---

## 🌍 GENERAL CONFIGURATION

# Environment type
ENVIRONMENT=development  # development | staging | production
APP_NAME=MedAI Nexus

---

## 🎨 FRONTEND (medical-web)

# Frontend environment (visible in browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=MedAI Nexus
NEXT_PUBLIC_LOG_LEVEL=debug

# Frontend-only secrets (if needed)
# Note: All NEXT_PUBLIC_ vars are visible in client code!

---

## 🔗 BACKEND (medical-api)

# Server configuration
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json  # json | text

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

---

## 🗄️ DATABASE (Neon PostgreSQL)

# Neon serverless PostgreSQL connection
# Format: postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:npg_xxxxx@ep-xxxx-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Database connection pool settings
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000

# Database logging
DATABASE_LOG_QUERIES=false

---

## 🔐 AUTHENTICATION & SECURITY

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-strong-string
JWT_EXPIRATION=3600  # seconds (1 hour)
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRATION=604800  # seconds (7 days)

# Password settings
PASSWORD_HASH_ROUNDS=10

# CSRF Protection
CSRF_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

---

## 📊 NEO4J GRAPH DATABASE

NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password

---

## 🤖 AI SERVICE (Python FastAPI)

# Python service configuration
FASTAPI_ENV=development
FASTAPI_PORT=8001
FASTAPI_LOG_LEVEL=INFO

# AI Service communication (from NestJS perspective)
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_TIMEOUT_MS=120000  # 2 minutes for analysis
AI_SERVICE_MAX_RETRIES=3
AI_SERVICE_RETRY_DELAY_MS=1000

# OpenAI configuration
OPENAI_API_KEY=sk-xxxxx  # Get from https://platform.openai.com/account/api-keys

---

## ⚙️ REDIS CACHE

REDIS_URL=redis://redis:6379

---

## 📁 AI SERVICE PATHS

FAISS_DATA_PATH=/data/faiss
MODELS_PATH=/models
FASTAPI_WORKERS=4

---

## 🧠 LLM CONFIGURATION

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2000

# Alternative: LLaMA (local)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Fallback LLM settings
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDER=ollama

---

## 📊 VECTOR DATABASE (FAISS/Chroma)

# Vector store configuration
VECTOR_DB_TYPE=faiss  # faiss | chroma
FAISS_DATA_PATH=/data/faiss
FAISS_INDEX_NAME=medical_index

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=32

# Vector store settings
VECTOR_STORE_SIMILARITY_THRESHOLD=0.6
VECTOR_STORE_TOP_K=5

---

## 📈 NEO4J (Knowledge Graph)

# Neo4j connection
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password_change_in_production
NEO4J_ENCRYPTED=false  # true for production

# Neo4j settings
NEO4J_CONNECTION_POOL_SIZE=10
NEO4J_IDLE_TIMEOUT_MS=60000

# Neo4j logging
NEO4J_LOG_QUERIES=false

---

## 🗄️ POSTGRESQL (Knowledge Storage - Read Only for AI)

# PostgreSQL read-only connection (for AI service)
POSTGRES_URL=postgresql://medai_user:medai_password@localhost:5432/medai_db
POSTGRES_POOL_SIZE=5

---

## 🔴 REDIS (Caching - Optional)

# Redis cache
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Cache settings
REDIS_CACHE_TTL_SECONDS=3600
REDIS_CACHE_ENABLED=true

# Redis cluster (production)
# REDIS_CLUSTER_ENABLED=false
# REDIS_CLUSTER_NODES=node1:6379,node2:6379

---

## 📁 FILE STORAGE

# Storage type
STORAGE_TYPE=local  # local | s3 | gcs

# Local storage
STORAGE_PATH=/uploads
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,tiff

# AWS S3 Storage
# AWS_S3_BUCKET=medai-uploads
# AWS_S3_REGION=us-east-1
# AWS_S3_ACCESS_KEY_ID=your-access-key
# AWS_S3_SECRET_ACCESS_KEY=your-secret-key

# Google Cloud Storage
# GCS_BUCKET=medai-uploads
# GCS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS_PATH=/path/to/credentials.json

---

## 🎯 AI SERVICE CONFIGURATION

# ML Models path
MODELS_PATH=/models
MODELS_CACHE_SIZE=5  # number of models to keep in memory

# OCR Configuration
OCR_ENGINE=tesseract  # tesseract | easyocr
OCR_LANGUAGE=eng

# NLP Configuration
NLP_TOKENIZER=nltk
NLP_REMOVE_STOPWORDS=true

# Feature extraction
NER_MODEL=en_core_sci_md

# Analysis settings
ANALYSIS_MAX_TIMEOUT_MS=120000
ANALYSIS_CONFIDENCE_THRESHOLD=0.5
ANALYSIS_ENABLE_CACHING=true

---

## 📊 MONITORING & LOGGING

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# DataDog (optional)
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ELK Stack (Elasticsearch, Logstash, Kibana)
ELK_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

---

## 🔧 DEVELOPMENT ONLY

# Debug mode
DEBUG=false

# API documentation
SWAGGER_ENABLED=true
SWAGGER_TITLE=MedAI Nexus API
SWAGGER_VERSION=1.0.0

# Testing
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/medai_test
TEST_DATABASE_RESET=true

# Seed data
SEED_DATABASE=false
SEED_DATA_PATH=/data/seeds

---

## 🌐 DEPLOYMENT SPECIFIC

### STAGING OVERRIDES
# ENVIRONMENT=staging
# DATABASE_URL=postgresql://user:pass@staging-db:5432/medai
# JWT_SECRET=staging-secret-key
# OPENAI_API_KEY=sk-staging-key
# AI_SERVICE_URL=http://ai-service.staging:8001

### PRODUCTION OVERRIDES
# ENVIRONMENT=production
# NODE_ENV=production
# DEBUG=false
# DATABASE_URL=postgresql://user:pass@prod-db:5432/medai
# JWT_SECRET=prod-secret-key-from-vault
# OPENAI_API_KEY=sk-prod-key-from-vault
# AI_SERVICE_URL=https://ai.medainexus.com
# NEXT_PUBLIC_API_URL=https://api.medainexus.com

---

## 📋 CHECKLIST FOR DEVELOPERS

### Local Development Setup
- [ ] Copy .env.example to .env.local
- [ ] Update DATABASE_URL with local PostgreSQL
- [ ] Update NEO4J_URL with local Neo4j
- [ ] Update REDIS_URL with local Redis
- [ ] Get OPENAI_API_KEY from team
- [ ] Verify all services start: `docker-compose up`
- [ ] Run migrations: `pnpm prisma:migrate:dev`
- [ ] Start backend: `pnpm start:dev`
- [ ] Start AI service: `python -m uvicorn app.main:app`
- [ ] Start frontend: `pnpm dev`

### Before Committing
- [ ] NEVER commit .env.local
- [ ] NEVER commit actual API keys
- [ ] Only update .env.example with template values
- [ ] Document any new environment variables

### Before Production Deployment
- [ ] All secrets in Secrets Manager (not .env)
- [ ] HTTPS enforced (NEXT_PUBLIC_API_URL=https://...)
- [ ] JWT_SECRET is strong (32+ characters, random)
- [ ] Rate limiting enabled
- [ ] CORS properly configured
- [ ] Logging level set to appropriate level
- [ ] Database backups configured
- [ ] Monitoring enabled

---

**Generated for MedAI Nexus**  
**NEVER commit sensitive values to version control**
