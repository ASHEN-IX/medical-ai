# MLflow Configuration
# Save as: docker/mlflow.env or .env.mlflow

# MLflow Tracking URI
MLFLOW_TRACKING_URI=file:./mlruns

# MLflow Experiment
MLFLOW_EXPERIMENT_NAME=medai_models

# MLflow Artifact Storage (local)
MLFLOW_ARTIFACT_ROOT=./mlflow_artifacts

# For production, use S3:
# MLFLOW_TRACKING_URI=http://mlflow-server:5000
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com

# For PostgreSQL backend:
# MLFLOW_BACKEND_STORE_URI=postgresql://user:password@postgres:5432/mlflow

# ===== Prometheus Configuration =====
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PORT=8001

# ===== Drift Detection =====
DRIFT_DETECTION_ENABLED=true
DRIFT_WINDOW_SIZE=100
DRIFT_FEATURE_THRESHOLD=0.2
DRIFT_PREDICTION_THRESHOLD=0.15

# ===== Prediction Logging =====
PREDICTION_LOGGING_ENABLED=true
PREDICTION_LOG_FILE=prediction_logs.jsonl
BACKEND_LOGGING_API_URL=http://backend:4000

# ===== Model Configuration =====
MODELS_PATH=/models
MODEL_LOAD_TIMEOUT_SECONDS=30
