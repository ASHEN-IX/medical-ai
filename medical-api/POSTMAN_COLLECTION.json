            "url": {
              "raw": "{{base_url}}{{api_path}}/logs/recent?hours=24",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "logs",
                "recent"
              ],
              "query": [
                {
                  "key": "hours",
                  "value": "24",
                  "description": "Get logs from last N hours"
                }
              ]
            },
            "description": "Get recent logs within specified hours (Admin only)"
          },
          "response": []
