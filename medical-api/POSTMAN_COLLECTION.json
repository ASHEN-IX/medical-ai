    {
      "name": "🤖 AI Predictions",
      "description": "AI prediction storage and retrieval endpoints",
      "item": [
        {
          "name": "Create Prediction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('prediction_id', jsonData.id);",
                  "    console.log('✅ Prediction ID saved: ' + jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportId\": \"{{report_id}}\",\n  \"disease\": \"Pneumonia\",\n  \"confidence\": {{$randomInt}},\n  \"explanation\": \"The chest X-ray shows consolidation in the left lower lobe consistent with bacterial pneumonia. Recommend antibiotic therapy and follow-up imaging in 2-3 weeks.\",\n  \"metadata\": {\n    \"model\": \"MedAI-ResNet50-v2.1\",\n    \"processingTime\": 1250,\n    \"region_of_interest\": \"lower_lobe_left\",\n    \"confidence_threshold\": 0.85,\n    \"version\": \"2.1.0\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_path}}/predictions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "predictions"
              ]
            },
            "description": "Create a new AI prediction (Doctor/Admin only, auto-saves prediction ID)"
          },
          "response": []
        },
        {
          "name": "Get Predictions for Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/predictions/report/{{report_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "predictions",
                "report",
                "{{report_id}}"
              ]
            },
            "description": "Get all predictions for a specific report"
          },
          "response": []
        },
        {
          "name": "Get Prediction by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/predictions/{{prediction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "predictions",
                "{{prediction_id}}"
              ]
            },
            "description": "Get specific prediction by ID"
          },
          "response": []
        }
      ]
