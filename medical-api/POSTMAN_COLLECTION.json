{
  "info": {
    "_postman_id": "medai-nexus-api",
    "name": "MedAI Nexus API",
    "description": "Complete testing collection for MedAI Nexus backend with Docker and Postman",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "Authentication endpoints - register, login, get profile",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@test.local\",\n  \"password\": \"TestPass123!\",\n  \"name\": \"New Test User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_path}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.access_token);",
                  "    console.log('✅ Token saved: ' + jsonData.access_token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_path}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "auth",
                "login"
              ]
            },
            "description": "Login and get JWT token (auto-saves to jwt_token)"
          },
          "response": []
        },
        {
          "name": "Get Current Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/auth/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "auth",
                "profile"
              ]
            },
            "description": "Get current user's profile (requires valid JWT token)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "👥 Users",
      "description": "User management endpoints",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "users",
                "me"
              ]
            },
            "description": "Get your own user profile"
          },
          "response": []
        },
        {
          "name": "Get All Users (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        pm.environment.set('user_id', jsonData[0].id);",
                  "        console.log('✅ User ID saved: ' + jsonData[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "users"
              ]
            },
            "description": "Get all users (Admin only - auto-saves first user ID)"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}{{api_path}}/users/{{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "users",
                "{{user_id}}"
              ]
            },
            "description": "Get specific user by ID (Doctor/Admin can view other users)"
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated User Name - {{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_path}}/users/{{user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "users",
                "{{user_id}}"
              ]
            },
            "description": "Update user information"
          },
          "response": []
        }
      ]
    },
    {
      "name": "📋 Medical Reports",
      "description": "Medical report management endpoints",
      "item": [
        {
          "name": "Create Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('report_id', jsonData.id);",
                  "    console.log('✅ Report ID saved: ' + jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"Chest-XRay-{{$timestamp}}.pdf\",\n  \"fileUrl\": \"https://storage.example.com/reports/xray-{{$randomInt}}.pdf\",\n  \"extractedData\": {\n    \"type\": \"Chest X-Ray\",\n    \"date\": \"2026-04-17\",\n    \"findings\": \"Normal chest radiograph. No acute cardiopulmonary process.\",\n    \"radiologist\": \"Dr. Smith\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_path}}/reports",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_path}}",
                "reports"
              ]
            },
            "description": "Create a new medical report (auto-saves report ID)"
          },
          "response": []
        },
