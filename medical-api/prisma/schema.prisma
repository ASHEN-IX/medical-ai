generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  age               Int?
  gender            Gender?
  medicalBackground String?
  phone             String?

  medicalReports   MedicalReport[]
  predictions      Prediction[]
  analyses         Analysis[]
  logs             Log[]
  doctorProfile    DoctorProfile?
  doctorRequests   DoctorRequest[]   @relation("PatientRequests")
  assignedRequests DoctorRequest[]   @relation("DoctorAssigned")
  doctorReviews    DoctorReview[]
  sentMessages     Message[]         @relation("SentMessages")
  receivedMessages Message[]         @relation("ReceivedMessages")
  healthMetrics    HealthMetric[]

  // --- New relations ---
  patientCases       CaseAssignment[]  @relation("PatientCases")
  doctorCases        CaseAssignment[]  @relation("DoctorCases")
  patientAppointments Appointment[]    @relation("PatientAppointments")
  doctorAppointments  Appointment[]    @relation("DoctorAppointments")
  conversationParticipations ConversationParticipant[]
  transportBookings  TransportationBooking[]
  prescriptionsGiven Prescription[]   @relation("DoctorPrescriptions")
  prescriptionsReceived Prescription[] @relation("PatientPrescriptions")
  medicationReminders MedicationReminder[]
  alerts             Alert[]
  preventionPlans    PreventionPlan[]
  manualTests        ManualTest[]
  historyEvents      ConsultationHistoryEvent[]
  stagedDiagnoses    StagedDiagnosis[]
  patientConsents    FamilyConsent[]   @relation("PatientConsents")
  caregiverConsents  FamilyConsent[]   @relation("CaregiverConsents")

  @@index([email])
}

model DoctorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty       String
  licenseNo       String?
  verified        Boolean  @default(false)
  bio             String?
  availableFrom   String?  // e.g. "09:00"
  availableTo     String?  // e.g. "17:00"
  maxCaseload     Int      @default(20)
  currentCaseload Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([specialty])
  @@index([verified])
}

model MedicalReport {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl       String
  fileName      String?
  fileType      String?
  extractedData Json?
  rawText       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  predictions Prediction[]
  analyses    Analysis[]
  extraction  ExtractedReportData?

  @@index([userId])
  @@index([createdAt])
}

model ExtractedReportData {
  id             String        @id @default(uuid())
  reportId       String        @unique
  report         MedicalReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  disease        String
  data           Json
  method         String        // gemini, gemini_partial, fallback_regex
  attempts       Int
  rawText        String?
  createdAt      DateTime      @default(now())
}

model Prediction {
  id          String        @id @default(uuid())
  reportId    String
  report      MedicalReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease     String
  confidence  Float         @default(0.0)
  explanation String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([reportId])
  @@index([userId])
  @@index([createdAt])
}

model Analysis {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId       String?
  report         MedicalReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  testName       String
  selectedModels String[]
  features       Json
  symptoms       String[]
  results        Json
  confidence     Float?
  healthScore    Int?
  riskLevel      RiskLevel     @default(LOW)
  keyFindings    String[]
  aiInsights     String?
  status         AnalysisStatus @default(COMPLETED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  doctorRequests  DoctorRequest[]
  doctorReviews   DoctorReview[]
  caseAssignments CaseAssignment[]
  manualTests     ManualTest[]

  @@index([userId])
  @@index([riskLevel])
  @@index([status])
  @@index([createdAt])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnalysisStatus {
  PROCESSING
  COMPLETED
  REVIEWED
  FLAGGED
}

model DoctorRequest {
  id         String              @id @default(uuid())
  patientId  String
  patient    User                @relation("PatientRequests", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String?
  doctor     User?               @relation("DoctorAssigned", fields: [doctorId], references: [id], onDelete: SetNull)
  analysisId String
  analysis   Analysis            @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  specialty  String?
  urgency    UrgencyLevel        @default(NORMAL)
  status     DoctorRequestStatus @default(PENDING)
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
}

enum UrgencyLevel {
  LOW
  NORMAL
  URGENT
  EMERGENCY
}

enum DoctorRequestStatus {
  PENDING
  ASSIGNED
  IN_REVIEW
  COMPLETED
  CANCELLED
}

model DoctorReview {
  id              String        @id @default(uuid())
  doctorId        String
  doctor          User          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  analysisId      String
  analysis        Analysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  diagnosis       String?
  notes           String?
  recommendations String[]
  prescription    String?
  aiApproved      Boolean?
  aiCorrection    String?
  reminderSent    Boolean?      @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([doctorId])
  @@index([analysisId])
  @@index([createdAt])
}

model Message {
  id             String        @id @default(uuid())
  senderId       String
  sender         User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId     String?
  receiver       User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  content        String
  messageType    MessageType   @default(TEXT)
  fileUrl        String?
  fileName       String?
  read           Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

model Conversation {
  id        String   @id @default(uuid())
  title     String?
  type      ConversationType @default(DIRECT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]

  @@index([createdAt])
}

enum ConversationType {
  DIRECT
  GROUP
  CASE
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model HealthMetric {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricKey String
  value     Float
  unit      String?
  source    String?
  createdAt DateTime @default(now())

  @@index([userId, metricKey])
  @@index([createdAt])
}

model Log {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model PredictionLog {
  id                String   @id @default(uuid())
  reportId          String
  modelId           String
  modelVersion      String
  inputFeatures     Json
  prediction        Json
  confidence        Float
  processingTimeMs  Float
  driftDetected     Boolean  @default(false)
  driftAlerts       Json?
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([reportId])
  @@index([modelId])
  @@index([createdAt])
  @@index([driftDetected])
}

// ============================================================
// NEW MODELS — Healthcare Ecosystem Extension
// ============================================================

model CaseAssignment {
  id         String               @id @default(uuid())
  patientId  String
  patient    User                 @relation("PatientCases", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String?
  doctor     User?                @relation("DoctorCases", fields: [doctorId], references: [id], onDelete: SetNull)
  analysisId String
  analysis   Analysis             @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  disease    String
  specialty  String
  status     CaseStatus           @default(PENDING)
  priority   UrgencyLevel         @default(NORMAL)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  appointments  Appointment[]
  prescriptions Prescription[]
  dynamicQuestions DynamicQuestion[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([specialty])
  @@index([createdAt])
}

enum CaseStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Appointment {
  id               String            @id @default(uuid())
  patientId        String
  patient          User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId         String
  doctor           User              @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  caseAssignmentId String?
  caseAssignment   CaseAssignment?   @relation(fields: [caseAssignmentId], references: [id], onDelete: SetNull)
  scheduledAt      DateTime
  durationMinutes  Int               @default(30)
  type             AppointmentType   @default(IN_PERSON)
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  reminderSent     Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  teleconsultation  Teleconsultation?
  transportBooking  TransportationBooking?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
}

enum AppointmentType {
  IN_PERSON
  TELECONSULTATION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Teleconsultation {
  id            String                  @id @default(uuid())
  appointmentId String                  @unique
  appointment   Appointment             @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  roomId        String                  @unique @default(uuid())
  status        TeleconsultationStatus  @default(WAITING)
  startedAt     DateTime?
  endedAt       DateTime?
  sessionNotes  String?
  recordingUrl  String?
  createdAt     DateTime                @default(now())

  @@index([roomId])
  @@index([status])
}

enum TeleconsultationStatus {
  WAITING
  ACTIVE
  PAUSED
  ENDED
}

model TransportationBooking {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentId String?         @unique
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  vehicleType   VehicleType     @default(STANDARD)
  pickupAddress String
  pickupLat     Float?
  pickupLng     Float?
  destAddress   String
  destLat       Float?
  destLng       Float?
  distanceKm    Float?
  estimatedMins Int?
  scheduledAt   DateTime
  status        BookingStatus   @default(PENDING)
  price         Float?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

enum VehicleType {
  AMBULANCE
  MEDICAL_TAXI
  STANDARD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Prescription {
  id               String          @id @default(uuid())
  doctorId         String
  doctor           User            @relation("DoctorPrescriptions", fields: [doctorId], references: [id], onDelete: Cascade)
  patientId        String
  patient          User            @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  caseAssignmentId String?
  caseAssignment   CaseAssignment? @relation(fields: [caseAssignmentId], references: [id], onDelete: SetNull)
  diagnosis        String?
  notes            String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  medications Medication[]

  @@index([doctorId])
  @@index([patientId])
  @@index([isActive])
  @@index([createdAt])
}

model Medication {
  id              String       @id @default(uuid())
  prescriptionId  String
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  name            String
  dosage          String
  frequency       String       // e.g. "twice daily"
  route           String?      // oral, injection, etc.
  startDate       DateTime
  endDate         DateTime?
  sideEffects     String[]
  instructions    String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reminders MedicationReminder[]

  @@index([prescriptionId])
  @@index([isActive])
}

model MedicationReminder {
  id           String         @id @default(uuid())
  medicationId String
  medication   Medication     @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  taken        Boolean        @default(false)
  takenAt      DateTime?
  skipped      Boolean        @default(false)
  notes        String?
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([medicationId])
  @@index([scheduledAt])
  @@index([taken])
}

model Alert {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AlertType
  severity    AlertSeverity @default(INFO)
  title       String
  message     String
  data        Json?
  read        Boolean     @default(false)
  dismissed   Boolean     @default(false)
  channel     String[]    @default(["in_app"])
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([type])
  @@index([severity])
  @@index([read])
  @@index([createdAt])
}

enum AlertType {
  CRITICAL_RISK
  TREND_WARNING
  MISSED_APPOINTMENT
  MEDICATION_REMINDER
  MEDICATION_NON_ADHERENCE
  DOCTOR_MESSAGE
  CASE_UPDATE
  CASE_ASSIGNMENT
  SYSTEM
  APPOINTMENT_SCHEDULED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_NO_SHOW
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  EMERGENCY
}

model PreventionPlan {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnoses       String[]
  riskFactors     String[]
  labValues       Json?
  dietGuidance    String[]
  exercisePlan    String[]
  sleepAdvice     String[]
  stressManagement String[]
  followUpTests   String[]
  additionalNotes String?
  generatedBy     String   @default("ai") // ai or doctor
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
}

model ManualTest {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease    String
  inputData  Json
  results    Json?
  analysisId String?
  analysis   Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  riskLevel  RiskLevel?
  confidence Float?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([disease])
  @@index([createdAt])
}

model ConsultationHistoryEvent {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType HistoryEventType
  title     String
  summary   String?
  metadata  Json?
  refId     String?   // reference ID to related entity
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

enum HistoryEventType {
  REPORT_UPLOAD
  AI_ANALYSIS
  MANUAL_TEST
  DOCTOR_REVIEW
  APPOINTMENT
  TELECONSULTATION
  PRESCRIPTION
  MESSAGE
  TRANSPORT
  ALERT
  PREVENTION_PLAN
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  targetId  String?
  resource  String
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}

model FamilyConsent {
  id          String       @id @default(uuid())
  patientId   String
  patient     User         @relation("PatientConsents", fields: [patientId], references: [id], onDelete: Cascade)
  caregiverId String
  caregiver   User         @relation("CaregiverConsents", fields: [caregiverId], references: [id], onDelete: Cascade)
  scope       ConsentScope @default(READ_ONLY)
  isActive    Boolean      @default(true)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())

  @@unique([patientId, caregiverId])
}

enum ConsentScope {
  READ_ONLY
  FULL_ACCESS
  EMERGENCY_ONLY
}

model StagedDiagnosis {
  id              String   @id @default(uuid())
  patientId       String
  patient         User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  disease         String
  initialReportId String?
  currentStep     Int      @default(0)
  isCompleted     Boolean  @default(false)
  answers         Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
}

model DynamicQuestion {
  id               String         @id @default(uuid())
  caseAssignmentId String
  caseAssignment   CaseAssignment @relation(fields: [caseAssignmentId], references: [id], onDelete: Cascade)
  questionText     String
  questionType     String         @default("TEXT")
  options          Json?
  severity         String         @default("INFO")
  category         String         @default("SYMPTOMS")
  orderIndex       Int            @default(0)
  answered         Boolean        @default(false)
  responses        Json?
  answeredAt       DateTime?
  isImportant      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([caseAssignmentId])
}
